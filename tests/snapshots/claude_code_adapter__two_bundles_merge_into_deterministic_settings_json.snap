---
source: tests/claude_code_adapter.rs
expression: parsed
---
hooks:
  PreToolUse:
    - hooks:
        - command: tests/fixtures/bundles/merge-a/hooks/guard.sh
          tool: ~
          type: command
      matcher: Bash
    - hooks:
        - command: tests/fixtures/bundles/merge-b/hooks/fmt.sh
          tool: ~
          type: command
      matcher: Edit
    - hooks:
        - command: llmenv config-guard
          type: command
      matcher: ^(Write|Edit|MultiEdit)$
  SessionStart:
    - hooks:
        - command: llmenv check-stale
          type: command
    - hooks:
        - command: llmenv config-context
          type: command
permissions:
  allow:
    - Bash(cargo *)
    - Read(./src)
  ask: []
  deny:
    - Read(./.env)
    - "WebFetch(domain:internal.example.com)"
    - "WebFetch(domain:other.example.com)"
