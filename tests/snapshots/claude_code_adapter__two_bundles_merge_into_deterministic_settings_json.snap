---
source: tests/claude_code_adapter.rs
expression: stable_parsed
---
hooks:
  PreToolUse:
    - hooks:
        - command: "<CACHE_DIR>/hooks/guard.sh"
          tool: ~
          type: command
      matcher: Bash
    - hooks:
        - command: "<CACHE_DIR>/hooks/fmt.sh"
          tool: ~
          type: command
      matcher: Edit
    - hooks:
        - command: llmenv config-guard --engine claude_code
          type: command
      matcher: ^(Write|Edit|MultiEdit)$
    - hooks:
        - command: llmenv hook-run --engine claude_code pre_tool_use
          type: command
      matcher: ^Read$
  SessionEnd:
    - hooks:
        - command: llmenv hook-run --engine claude_code session_end
          type: command
  SessionStart:
    - hooks:
        - command: llmenv check-stale --engine claude_code
          type: command
    - hooks:
        - command: llmenv config-context --engine claude_code
          type: command
    - hooks:
        - command: llmenv hook-run --engine claude_code session_start
          type: command
permissions:
  allow:
    - Bash(cargo *)
    - Read(./src)
  ask: []
  deny:
    - Read(./.env)
    - "WebFetch(domain:internal.example.com)"
    - "WebFetch(domain:other.example.com)"
